# ─────────────────────────────────────────────────
#  AI SEO Tool — Environment Variables
# ─────────────────────────────────────────────────
#
#  STEP 1: Copy this file and rename it to .env
#  STEP 2: Fill in your API keys below
#  STEP 3: Add these same variables in Netlify:
#          Site Settings → Environment Variables
#
# ─────────────────────────────────────────────────

# REQUIRED — Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# OPTIONAL — Add later to upgrade to Path B (Ahrefs)
# AHREFS_API_KEY=YOUR_AHREFS_KEY_HERE
